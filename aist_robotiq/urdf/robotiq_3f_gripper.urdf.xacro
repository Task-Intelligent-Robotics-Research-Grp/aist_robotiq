<?xml version="1.0" ?>
<robot name="robotiq-3f-gripper_articulated"
       xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="robotiq_3f_gripper" params="prefix parent *origin">

    <xacro:property name="tip_height"		value="0.204"/>
    <xacro:property name="distal_length"	value="0.0335"/>
    <xacro:property name="distal_offset"	value="0.0095"/>

    <xacro:macro name="set_frame" params="name parent *origin">
      <joint name="${name}_joint" type="fixed">
	<parent link="${parent}"/>
	<child  link="${name}"/>
	<xacro:insert_block name="origin"/>
      </joint>
      <link name="${name}"/>
    </xacro:macro>

    <xacro:macro name="robotiq_3f_finger" params="fingerprefix">
      <link name="${fingerprefix}base_link">
	<visual>
	  <origin rpy="0 0 0" xyz="0.020 0 0"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/visual/robotiq_3f_link_0.dae"/>
	  </geometry>
	  <material name="green">
            <color rgba="0 1 0 1"/>
	  </material>
	</visual>
	<collision>
	  <origin rpy="0 0 0" xyz="0.020 0 0"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/collision/robotiq_3f_link_0.stl"/>
	  </geometry>
	  <material name="yellow">
            <color rgba="0 1 1 1"/>
	  </material>
	</collision>
	<inertial>
	  <origin rpy="0 0 0" xyz="0 0 0"/>
	  <mass value="0.05"/>
	  <inertia ixx="0.01" ixy="-0.00002" ixz="0.00001"
		   iyy="0.0008" iyz="0" izz="0.001"/>
	</inertial>
      </link>

      <joint name="${fingerprefix}joint" type="revolute">
	<parent link="${fingerprefix}base_link"/>
	<child link="${fingerprefix}proximal_link"/>
	<axis xyz="0 0 1"/>
	<origin xyz="0.020 0 0" rpy="0 0 0"/>
	<limit effort="100" lower="0" upper="${radians(120)}" velocity="100"/>
      </joint>
      <link name="${fingerprefix}proximal_link">
	<visual>
	  <origin xyz="0.050 -.028 0" rpy="0 0 ${radians(-30)}"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/visual/robotiq_3f_link_1.dae"/>
	  </geometry>
	  <material name="green"/>
	</visual>
	<collision>
	  <origin xyz="0.050 -.028 0" rpy="0 0 ${radians(-30)}"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/collision/robotiq_3f_link_1.stl"/>
	  </geometry>
	  <material name="yellow"/>
	</collision>
	<inertial>
	  <origin xyz="0 0 0" rpy="0 0 0"/>
	  <mass value="0.15"/>
	  <inertia ixx="0.001859" ixy="-0.000376" ixz="0.000028"
		   iyy="0.012756" iyz="0" izz="0.0024"/>
	</inertial>
      </link>

      <joint name="${fingerprefix}medial_joint" type="revolute">
	<parent link="${fingerprefix}proximal_link"/>
	<child link="${fingerprefix}medial_link"/>
	<axis xyz="0 0 1"/>
	<origin xyz="0.050 -.028 0" rpy="0 0 ${radians(-30)}"/>
	<limit effort="100" lower="0" upper="${radians(120)}" velocity="100"/>
	<mimic joint="${fingerprefix}joint" multiplier="0" offset="0"/>
      </joint>
      <link name="${fingerprefix}medial_link">
	<!--
	    NOTE: This link has an offset in the z-direction based on the models that were
	    used to generate grap-it poses.  With the offset below the model appears visually
	    correct, but it is suspect.
	-->
	<visual>
	  <origin xyz="0.039 0 0.0075" rpy="0 0 0"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/visual/robotiq_3f_link_2.dae"/>
	  </geometry>
	  <material name="green"/>
	</visual>
	<collision>
	  <origin xyz="0.039 0 0.0075" rpy="0 0 0"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/collision/robotiq_3f_link_2.stl"/>
	  </geometry>
	  <material name="yellow"/>
	</collision>
	<inertial>
	  <origin xyz="0 0 0" rpy="0 0 0"/>
	  <mass value="0.15"/>
	  <inertia ixx="0.001859" ixy="-0.000376" ixz="0.000028"
		   iyy="0.012756" iyz="0" izz="0.0024"/>
	</inertial>
      </link>

      <joint name="${fingerprefix}distal_joint" type="revolute">
	<parent link="${fingerprefix}medial_link"/>
	<child link="${fingerprefix}distal_link"/>
	<axis xyz="0 0 1"/>
	<origin xyz="0.039 0 0" rpy="0 0 0"/>
	<limit effort="100" lower="0" upper="${radians(120)}" velocity="100"/>
	<mimic joint="${fingerprefix}joint"
	       multiplier="-1" offset="0"/>
      </joint>
      <link name="${fingerprefix}distal_link">
	<visual>
	  <origin xyz="0 0 0" rpy="0 0 ${radians(30)}"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/visual/robotiq_3f_link_3.dae"/>
	  </geometry>
	  <material name="green"/>
	</visual>
	<collision>
	  <origin xyz="0 0 0" rpy="0 0 ${radians(30)}"/>
	  <geometry>
            <mesh filename="package://aist_robotiq/meshes/collision/robotiq_3f_link_3.stl"/>
	  </geometry>
	  <material name="yellow"/>
	</collision>
	<inertial>
	  <origin xyz="0 0 0" rpy="0 0 0"/>
	  <mass value="0.05"/>
	  <inertia ixx="0.001239" ixy="-0.000251" ixz="0.000019"
		   iyy="0.00085" iyz="0" izz="0.001632"/>
	</inertial>
      </link>

      <xacro:set_frame name="${fingerprefix}tip_link"
		       parent="${fingerprefix}distal_link">
	<origin xyz="${distal_length*cos(radians(30))}
		     ${distal_length*sin(radians(30)) + distal_offset}
		     0.0"
		rpy="0 0 ${radians(30)}"/>
      </xacro:set_frame>

    </xacro:macro>

    <!-- Base -->
    <link name="${prefix}base_link"/>
    <joint name="${prefix}base_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${prefix}base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <!-- Palm -->
    <joint name="${prefix}palm_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child  link="${prefix}palm"/>
      <origin xyz="0.052 0.0 0.0" rpy="0 0 ${radians(-90)}"/>
    </joint>
    <link name="${prefix}palm">
      <visual>
	<geometry>
          <mesh filename="package://aist_robotiq/meshes/visual/robotiq_3f_palm.dae"/>
	</geometry>
	<material name="green">
          <color rgba="0 1 0 1"/>
	</material>
      </visual>
      <collision>
	<geometry>
          <mesh filename="package://aist_robotiq/meshes/collision/robotiq_3f_palm.stl"/>
	</geometry>
	<material name="yellow">
          <color rgba="0 1 1 1"/>
	</material>
      </collision>
      <inertial>
	<origin rpy="0 0 0" xyz="0 0 0"/>
	<mass value="1.3"/>
	<inertia ixx="0.006012" ixy="0.000079" ixz="-0.00024"
		 iyy="0.012892" iyz="0" izz="0.002435"/>
      </inertial>
    </link>

    <!-- Gripper tip -->
    <xacro:set_frame name="${prefix}tip_link"
		     parent="${prefix}base_link">
      <origin xyz="${tip_height} 0.0 0.0" rpy="0 ${radians(-90)} 0"/>
    </xacro:set_frame>

    <!-- middle finger -->
    <joint name="${prefix}palm_finger_middle_joint" type="fixed">
      <parent link="${prefix}palm"/>
      <child link="${prefix}middle_finger_base_link"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0.0455 0.0214 0" rpy="0 0 ${radians(90)}"/>
    </joint>
    <xacro:robotiq_3f_finger fingerprefix="${prefix}middle_finger_"/>

    <!-- left finger -->
    <joint name="${prefix}scissor_joint" type="revolute">
      <parent link="${prefix}palm"/>
      <child link="${prefix}left_finger_base_link"/>
      <axis xyz="0 1 0"/>
      <origin xyz="-0.0455 0.0214 -0.036"
	      rpy="0 ${radians(180)} ${radians(-90)}"/>
      <limit effort="100" lower="-0.25" upper="0.16" velocity="100"/>
    </joint>
    <xacro:robotiq_3f_finger fingerprefix="${prefix}left_finger_"/>

    <!-- right finger -->
    <joint name="${prefix}right_finger_scissor_joint" type="revolute">
      <parent link="${prefix}palm"/>
      <child link="${prefix}right_finger_base_link"/>
      <axis xyz="0 1 0"/>
      <origin xyz="-0.0455 0.0214 0.036"
	      rpy="0 ${radians(180)} ${radians(-90)}"/>
      <limit effort="100" lower="-0.16" upper="0.25" velocity="100"/>
      <mimic joint="${prefix}scissor_joint" multiplier="-1" offset="0"/>
    </joint>
    <xacro:robotiq_3f_finger fingerprefix="${prefix}right_finger_"/>

    <!--
        <include filename="$(find aist_robotiq)/cfg/robotiq-3f-gripper_finger_articulated_macro.xacro" />
        <xacro:robotiq-3f-gripper_finger_articulated prefix=""/>
    -->
  </xacro:macro>
</robot>
